services:
  # 1. The Autonomous Brain (The "Brain")
  sub_brain:
    build: 
      context: .
      dockerfile: Dockerfile
    container_name: sub_brain
    network_mode: host
    privileged: true 
    volumes:
      - .:/ros2_ws/src/sub_ai_sim
    environment:
      - ROS_DOMAIN_ID=0
      - ROS_LOCALHOST_ONLY=1  # Forces nodes to talk on the same machine
      - RMW_IMPLEMENTATION=rmw_fastrtps_cpp # Standard ROS2 middleware
      - PYTHONUNBUFFERED=1
    # Runs your new ROS2 wrapper instead of the old main.py
    command: python3 /ros2_ws/src/sub_ai_sim/sub_brain_node.py
    stdin_open: true
    tty: true
    restart: always

  # 2. The Simulated Environment (The "World")
  mock_sensors:
    build: 
      context: .
      dockerfile: Dockerfile
    container_name: mock_sensors
    network_mode: host
    volumes:
      - .:/ros2_ws/src/sub_ai_sim
    environment:
      - ROS_DOMAIN_ID=0
      - ROS_LOCALHOST_ONLY=1  # Forces nodes to talk on the same machine
      - RMW_IMPLEMENTATION=rmw_fastrtps_cpp # Standard ROS2 middleware
      - PYTHONUNBUFFERED=1
    # Runs the node that feeds fake IMU/Depth/Camera data to the brain
    command: python3 /ros2_ws/src/sub_ai_sim/mock_sensor_node.py
    stdin_open: true
    tty: true
